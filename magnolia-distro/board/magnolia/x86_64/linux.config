# Magnolia Minimal Kernel Configuration (Linux 7.0 target)

# Architecture
CONFIG_64BIT=y
CONFIG_X86_64=y

# Processor
CONFIG_GENERIC_CPU=y
CONFIG_SMP=y

# Boot
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EARLY_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# Core Utilities
CONFIG_UNIX=y
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y

# Drivers - Graphics (Wayland/Cage Support)
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_I915_FORCE_PROBE="*"
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_NOUVEAU=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_MIPI_DSI=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER=y

# Drivers - Input
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_SQUASHFS=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y

# Update Support (RAUC/AB)
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_CRYPT=y
CONFIG_DM_VERITY=y

# Drivers - Storage
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y

# Virtualization (Hardened for Magnolia)
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
